# === GovernLayer Environment ===

# LLM (required)
GROQ_API_KEY=gsk_your_key_here

# Database
DATABASE_URL=postgresql://localhost/governlayer

# Auth (CHANGE IN PRODUCTION)
SECRET_KEY=generate-a-real-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# LLM Config
LLM_MODEL=llama-3.3-70b-versatile

# Local LLM (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b
USE_LOCAL_LLM=false

# OpenRouter (universal gateway — 500+ models including Gemini, GPT, Grok, Kimi, DeepSeek)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Achonye Multi-LLM Orchestration
ACHONYE_PREFER_LOCAL=true
ACHONYE_CONSENSUS_CRITICAL=true
ACHONYE_LEADER_MODEL=claude-opus

# Redis
REDIS_URL=redis://localhost:6379/0

# Drift Detection
DRIFT_MODEL=all-MiniLM-L6-v2
DRIFT_THRESHOLD=0.3

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false
