# =============================================================================
# GovernLayer.ai — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql://localhost/governlayer
# For Docker:
# DATABASE_URL=postgresql://governlayer:YOUR_PASSWORD@postgres:5432/governlayer
POSTGRES_USER=governlayer
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=governlayer

# --- Authentication ---
# CRITICAL: Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_GENERATE_WITH_COMMAND_ABOVE
JWT_EXPIRY_HOURS=24

# --- LLM: Groq (fast cloud inference) ---
# Get key at: https://console.groq.com/keys
GROQ_API_KEY=

# --- LLM: OpenRouter (universal gateway — GPT-4o, Gemini, Claude, Grok, 500+ models) ---
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# --- LLM: Ollama (local inference — free, private) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b
USE_LOCAL_LLM=false

# --- Achonye Orchestration ---
ACHONYE_PREFER_LOCAL=true
ACHONYE_CONSENSUS_CRITICAL=true
ACHONYE_LEADER_MODEL=claude-opus

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
# For Docker:
# REDIS_URL=redis://:YOUR_REDIS_PASSWORD@redis:6379/0
REDIS_PASSWORD=CHANGE_ME

# --- Drift Detection ---
DRIFT_MODEL=all-MiniLM-L6-v2
DRIFT_THRESHOLD=0.3

# --- Server ---
HOST=0.0.0.0
PORT=8000
DEBUG=false

# --- CORS ---
# Comma-separated allowed origins. Set to your actual domain(s) in production!
# Example: https://governlayer.ai,https://app.governlayer.ai,https://dashboard.governlayer.ai
CORS_ORIGINS=https://governlayer.ai

# --- Policy ---
POLICY_VERSION=1.0.0
